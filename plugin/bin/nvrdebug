#!/usr/bin/env bash
SCRIPT_LOCATION="$( cd "$( dirname "$0" )" && pwd )"
source "$SCRIPT_LOCATION/funcs.sh"

echo "=== nvrdebug ==="
echo "TMUX env var: '$TMUX'"
echo "NVIM env var: '$NVIM'"
echo "NVIM_LISTEN_ADDRESS env var: '$NVIM_LISTEN_ADDRESS'"
echo "---"
echo "tmux show-environment -g NVIM output:"
tmux show-environment -g NVIM 2>&1
echo "---"
echo "get_nvim_socket() returns: '$(get_nvim_socket)'"
echo "---"
echo "Testing nvr_cmd --test:"
nvr_cmd --test 2>&1
